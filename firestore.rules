rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Allow any authenticated user to read other users' profiles (display names)
    match /users/{userId}/profile/{docId} {
      allow read: if request.auth != null;
    }
    // Allow any authenticated user to read other users' decisions (for team dashboard)
    match /users/{userId}/projects/{projectId}/decisions/{paperId} {
      allow read: if request.auth != null;
    }
    // Allow any authenticated user to create notifications for other users
    match /users/{userId}/notifications/{notifId} {
      allow create: if request.auth != null;
    }
    match /projects/{projectId}/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /invites/{email}/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /bugReports/{reportId} {
      allow read, write: if request.auth != null;
    }
    match /{path=**}/collaborators/{email} {
      allow read: if request.auth != null;
    }
  }
}
